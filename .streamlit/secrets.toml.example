# ── 访问密码（两个 app 共用；不设则不锁）──────────────────────────────────
APP_PASSWORD = "请改成你自己的强密码"

# ── Agent 的 LLM 配置（仅 app_agent.py 用）──────────────────────────────
# 不设这些 → app_agent 走「离线规则路由」，仍可演示工具链，但不调 LLM。
#
# DeepSeek 示例（便宜、中文好）：
OPENAI_API_KEY  = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_BASE_URL = "https://api.deepseek.com/v1"
AGENT_LLM_MODEL = "deepseek-chat"
#
# OpenAI 官方：注释掉 OPENAI_BASE_URL，把 MODEL 改成 gpt-4o-mini
# Moonshot / 自建 vLLM 等 OpenAI 兼容端点同理换 BASE_URL 和 MODEL。
